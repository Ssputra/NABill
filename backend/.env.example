# ============================================================
# Konfigurasi Server
# ============================================================
PORT=3000

# ============================================================
# Database SQLite
# ============================================================
DB_PATH=./data/billing.db

# ============================================================
# JWT Secret (ganti dengan string acak panjang!)
# ============================================================
JWT_SECRET=ganti_dengan_string_rahasia_yang_panjang_dan_acak_min_32_karakter

# ============================================================
# MikroTik Router - Isi sesuai router Anda
# ============================================================
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASS=password_mikrotik
MIKROTIK_TIMEOUT=10

# ============================================================
# Aplikasi
# ============================================================
APP_NAME=RT/RW NET Billing
APP_VERSION=2.0

# ============================================================
# Password Akun Default (hanya dipakai saat DB pertama dibuat)
# Segera ubah setelah pertama login!
# ============================================================
DEFAULT_ADMIN_PASSWORD=ganti_password_admin_anda
DEFAULT_KASIR_PASSWORD=ganti_password_kasir_anda
DEFAULT_TEKNISI_PASSWORD=ganti_password_teknisi_anda
